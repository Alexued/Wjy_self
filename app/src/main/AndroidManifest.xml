<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 悬浮窗权限 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- 前台服务权限 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- 录屏前台服务权限 (Android 14+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <!-- 网络权限（调用 AI API） -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AIAssistant">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 知识卡片列表 -->
        <activity
            android:name=".knowledge.KnowledgeCardListActivity"
            android:exported="false"
            android:theme="@style/Theme.AIAssistant" />

        <!-- 知识卡片编辑 -->
        <activity
            android:name=".knowledge.KnowledgeCardEditActivity"
            android:exported="false"
            android:theme="@style/Theme.AIAssistant"
            android:windowSoftInputMode="adjustResize" />

        <!-- 做题页面 -->
        <activity
            android:name=".questionbank.PracticeActivity"
            android:exported="false"
            android:theme="@style/Theme.AIAssistant" />

        <!-- 番茄钟设置 -->
        <activity
            android:name=".pomodoro.PomodoroSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.AIAssistant" />

        <!-- 番茄钟统计与历史 -->
        <activity
            android:name=".pomodoro.PomodoroStatsActivity"
            android:exported="false"
            android:theme="@style/Theme.AIAssistant" />

        <!-- MediaProjection 重新授权（透明 Activity，无 UI） -->
        <activity
            android:name=".MediaProjectionConsentActivity"
            android:exported="false"
            android:theme="@style/Theme.Transparent"
            android:excludeFromRecents="true"
            android:noHistory="true" />

        <!-- 录屏 + 悬浮球前台服务 -->
        <service
            android:name=".ScreenCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- 导出卡片图片分享 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>