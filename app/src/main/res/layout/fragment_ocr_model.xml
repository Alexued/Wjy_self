<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border_light"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/background_card_glass">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OCR 识别方式"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <RadioGroup
                    android:id="@+id/rg_ocr_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rb_ocr_local"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="本地 OCR（PaddleOCR，离线识别）"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:layout_marginBottom="8dp" />

                    <RadioButton
                        android:id="@+id/rb_ocr_cloud"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="云端 OCR（Paddle 布局解析，联网识别）"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp" />
                </RadioGroup>

                <!-- 云端配置 -->
                <LinearLayout
                    android:id="@+id/layout_cloud_ocr_config"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp"
                    android:visibility="gone">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/card_divider"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="云端模型"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="8dp" />

                    <RadioGroup
                        android:id="@+id/rg_cloud_ocr_type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rb_ocr_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="布局解析（可识别下划线、数字、表格）"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:layout_marginBottom="4dp" />

                        <RadioButton
                            android:id="@+id/rb_ocr_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="文字识别（轻量快速）"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp" />
                    </RadioGroup>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/card_divider"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="API URL"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_cloud_ocr_url"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="https://...layout-parsing"
                            android:inputType="textUri"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="API Token"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        app:passwordToggleEnabled="true">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_cloud_ocr_token"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="输入 API Token"
                            android:inputType="textPassword"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_ocr"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="保存配置"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            app:backgroundTint="@color/primary"
            app:cornerRadius="14dp" />
    </LinearLayout>
</ScrollView>
