<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_alert"
    android:orientation="vertical"
    android:paddingHorizontal="24pt"
    android:paddingTop="24pt"
    android:paddingBottom="24pt">

    <!-- 标题 -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/colorTextPrimary"
        android:textSize="17pt"
        android:textStyle="bold" />

    <!-- 内容 -->
    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8pt"
        android:gravity="center"
        android:textColor="@color/colorTextTertiary"
        android:textSize="14pt"
        android:visibility="gone" />

    <!-- 按钮区域 -->
    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32pt"
        android:orientation="horizontal">

        <!-- 取消按钮 -->
        <com.apk.claw.android.widget.KButton
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="44pt"
            android:layout_weight="1"
            android:textSize="15pt"
            android:visibility="gone" />

        <View
            android:id="@+id/btnSpacer"
            android:layout_width="8pt"
            android:layout_height="0dp"
            android:visibility="gone" />

        <!-- 确认按钮 -->
        <com.apk.claw.android.widget.KButton
            android:id="@+id/btnAction"
            android:layout_width="0dp"
            android:layout_height="44pt"
            android:layout_weight="1"
            android:textSize="15pt" />

    </LinearLayout>

</LinearLayout>
