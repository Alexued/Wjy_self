<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:parentTag="android.widget.FrameLayout">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 标题 -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="32pt"
            android:paddingEnd="16pt"
            android:paddingTop="4pt"
            android:paddingBottom="4pt"
            android:textColor="@color/colorTextPrimary"
            android:textSize="14pt"
            android:visibility="gone"
            tools:text="分组标题"
            tools:visibility="visible" />

        <!-- 卡片容器 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16pt"
            android:layout_marginVertical="8pt"
            app:cardBackgroundColor="@color/colorBgPrimary"
            app:cardCornerRadius="12pt"
            app:cardElevation="0dp"
            app:strokeWidth="1pt"
            app:strokeColor="@color/colorBorderHigh">

            <LinearLayout
                android:id="@+id/itemsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</merge>
