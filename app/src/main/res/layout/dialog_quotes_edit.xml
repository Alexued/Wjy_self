<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_quotes_dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="自定义顶部名言"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="主页顶部将循环呈现您库中的名言。若清空，将自动展现系统推荐的经典考公禅意名言。"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="12dp" />

    <!-- 列表标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="当前已存名言"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginBottom="6dp" />

    <!-- 滚动列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_quotes_list"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#05000000"
        android:padding="8dp"
        android:layout_marginBottom="16dp"
        android:scrollbars="vertical" />

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_light"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="新增名言警句"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:layout_marginBottom="8dp" />

    <!-- 名言正文输入 -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:hint="名言内容 (如：静心关照，笃行致远)"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_quote_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:inputType="textMultiLine"
            android:maxLines="3" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 名言出处输入 -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="出处/作者 (如：——《荀子》 或 诸葛亮)"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_quote_author"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:inputType="text"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 添加按钮与重置按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reset_quotes"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:text="恢复内置名言"
            android:textSize="12sp"
            android:textColor="@color/primary"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_quote"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:text="+ 添加至库"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            app:backgroundTint="@color/primary"
            app:cornerRadius="8dp" />
    </LinearLayout>

</LinearLayout>
