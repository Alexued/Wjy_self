<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部意境茶室 Banner 装饰区 (相框式挂件设计，内置参数按钮，完美融入背景) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="125dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border_light"
            app:strokeWidth="1.2dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/zen_pomo_banner"
                    android:scaleType="centerCrop"
                    android:contentDescription="禅意茶室" />

                <!-- 渐变阴影遮罩 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#20000000" />

                <!-- 标题文字区域 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:orientation="vertical"
                    android:layout_marginStart="18dp"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="静坐入定"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:letterSpacing="0.12" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="心静如水，水清月现 • 气定神闲"
                        android:textSize="10.5sp"
                        android:textColor="#E5E7EB"
                        android:letterSpacing="0.05" />
                </LinearLayout>

                <!-- 禅意设置按钮，右上角精巧布局 -->
                <ImageView
                    android:id="@+id/btn_settings"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="12dp"
                    android:src="@android:drawable/ic_menu_manage"
                    android:padding="9dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="参数调整"
                    app:tint="#FFFFFF" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 主体区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 计时器核心卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="26dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1.2dp"
                app:cardBackgroundColor="@color/background_card_glass"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="22dp">

                    <!-- 状态微章 -->
                    <TextView
                        android:id="@+id/tv_state_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="准备开始"
                        android:textSize="12.5sp"
                        android:textColor="@color/primary"
                        android:background="@drawable/bg_default_chip"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="3.5dp"
                        android:layout_marginBottom="22dp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />

                    <!-- 圆形进度环倒计时 -->
                    <FrameLayout
                        android:layout_width="210dp"
                        android:layout_height="210dp"
                        android:layout_gravity="center_horizontal">

                        <!-- 背景淡砂岩圆环 -->
                        <View
                            android:id="@+id/view_progress_bg"
                            android:layout_width="210dp"
                            android:layout_height="210dp"
                            android:background="@drawable/bg_circle_progress_bg" />

                        <!-- 禅意自定义刻度环 -->
                        <com.example.aiassistant.pomodoro.PomodoroProgressView
                            android:id="@+id/progress_view"
                            android:layout_width="210dp"
                            android:layout_height="210dp" />

                        <!-- 中心时间 -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tv_timer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="25:00"
                                android:textSize="42sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:fontFamily="monospace" />

                            <TextView
                                android:id="@+id/tv_phase"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="专注"
                                android:textSize="13.5sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="2dp"
                                android:letterSpacing="0.12" />
                        </LinearLayout>
                    </FrameLayout>

                    <!-- 当前任务 -->
                    <LinearLayout
                        android:id="@+id/layout_current_task"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginTop="18dp"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="5dp"
                        android:background="@drawable/bg_noise_chip"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tv_current_task"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="12.5sp"
                            android:textColor="@color/primary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- 今日累计 -->
                    <TextView
                        android:id="@+id/tv_today_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="今日 0/8 🍅"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="16dp"
                        android:letterSpacing="0.04" />

                    <!-- 操作按键 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:layout_marginTop="20dp">

                        <TextView
                            android:id="@+id/btn_select_task"
                            android:layout_width="wrap_content"
                            android:layout_height="42dp"
                            android:gravity="center"
                            android:paddingHorizontal="18dp"
                            android:text="研习任务"
                            android:textSize="13.5sp"
                            android:textColor="@color/text_secondary"
                            android:background="@drawable/bg_pomodoro_button_secondary"
                            android:layout_marginEnd="12dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btn_start"
                            android:layout_width="wrap_content"
                            android:layout_height="42dp"
                            android:gravity="center"
                            android:paddingHorizontal="28dp"
                            android:text="开始入定"
                            android:textSize="14.5sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:background="@drawable/bg_pomodoro_button"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <!-- 暂停/跳过按钮 (运行中显示) -->
                    <LinearLayout
                        android:id="@+id/layout_pause_skip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/btn_pause"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:gravity="center"
                            android:paddingHorizontal="18dp"
                            android:text="暂停"
                            android:textSize="13.5sp"
                            android:textColor="@color/text_secondary"
                            android:background="@drawable/bg_pomodoro_button_secondary"
                            android:layout_marginEnd="12dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btn_skip"
                            android:layout_width="wrap_content"
                            android:layout_height="38dp"
                            android:gravity="center"
                            android:paddingHorizontal="18dp"
                            android:text="跳过"
                            android:textSize="13.5sp"
                            android:textColor="@color/incorrect_red"
                            android:background="@drawable/bg_pomodoro_button_secondary"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 白噪音卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1.2dp"
                app:cardBackgroundColor="@color/background_card_glass"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="3.5dp"
                            android:layout_height="14dp"
                            android:background="@color/primary"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="白噪音 · 磬钟静心"
                            android:textSize="14.5sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:letterSpacing="0.04" />
                    </LinearLayout>

                    <!-- 磬声白噪音挑选 -->
                    <LinearLayout
                        android:id="@+id/layout_noise_chips"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/chip_rain"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="🌧️ 听雨"
                            android:textSize="12.5sp"
                            android:textColor="@color/text_secondary"
                            android:background="@drawable/bg_noise_chip"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/chip_cafe"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="☕ 墨香"
                            android:textSize="12.5sp"
                            android:textColor="@color/text_secondary"
                            android:background="@drawable/bg_noise_chip"
                            android:layout_marginEnd="8dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/chip_forest"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="🌲 空山"
                            android:textSize="12.5sp"
                            android:textColor="@color/text_secondary"
                            android:background="@drawable/bg_noise_chip"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <!-- 白音量滑动条 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔊"
                            android:textSize="14sp"
                            android:layout_marginEnd="8dp" />

                        <SeekBar
                            android:id="@+id/seekbar_volume"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:max="100"
                            android:progress="60"
                            android:progressTint="@color/primary"
                            android:thumbTint="@color/primary" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 今日修行统计卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_overview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1.2dp"
                app:cardBackgroundColor="@color/background_card_glass"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="14dp">

                        <View
                            android:layout_width="3.5dp"
                            android:layout_height="14dp"
                            android:background="@color/primary"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="今日功课概览"
                            android:textSize="14.5sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/btn_view_stats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="功课统计 ›"
                            android:textSize="12.5sp"
                            android:textColor="@color/primary"
                            android:textStyle="bold"
                            android:background="?attr/selectableItemBackground" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/stats_focus_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0m"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="专注时长"
                                android:textSize="11.5sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/stats_tomato_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/correct_green" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="已得番茄"
                                android:textSize="11.5sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/stats_completion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/tag_blue_text" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="目标进度"
                                android:textSize="11.5sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
