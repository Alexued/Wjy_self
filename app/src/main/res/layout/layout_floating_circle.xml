<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/floatRoot"
    android:layout_width="56pt"
    android:layout_height="56pt">

    <!-- 任务通知状态（胶囊展开，短暂显示后自动收回） -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTaskNotify"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        app:cardCornerRadius="28pt"
        app:cardElevation="4pt"
        app:cardBackgroundColor="@color/colorBrandPrimary"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16pt"
            android:paddingEnd="18pt">

            <ImageView
                android:id="@+id/ivNotifyChannelLogo"
                android:layout_width="20pt"
                android:layout_height="20pt"
                android:contentDescription="@string/cd_channel_logo"
                android:src="@drawable/ic_launcher"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/tvTaskNotify"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8pt"
                android:text=""
                android:textColor="@color/colorBrandOnPrimary"
                android:textSize="12pt"
                android:maxWidth="200pt"
                android:maxLines="2"
                android:ellipsize="end" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- 等待任务状态（默认） -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardIdle"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="28pt"
        app:cardElevation="4pt"
        app:cardBackgroundColor="@color/colorBrandPrimary">

        <TextView
            android:id="@+id/tvFloatTextIdle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/floating_ai_label"
            android:textColor="@color/colorBrandOnPrimary"
            android:textSize="16pt"
            android:textStyle="bold" />

    </com.google.android.material.card.MaterialCardView>

    <!-- 任务执行中状态 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardRunning"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="28pt"
        app:cardElevation="4pt"
        app:cardBackgroundColor="@color/colorBrandPrimary"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- 旋转的进度环 -->
            <ProgressBar
                android:id="@+id/progressRunning"
                android:layout_width="56pt"
                android:layout_height="56pt"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:indeterminateTint="@color/colorBrandOnPrimary"
                style="@style/Widget.AppCompat.ProgressBar" />

            <!-- 渠道 Logo -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivChannelLogo"
                android:layout_width="20pt"
                android:layout_height="20pt"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="12pt"
                android:contentDescription="@string/cd_channel_logo"
                android:src="@drawable/ic_launcher"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Launcher.Circle" />

            <!-- 轮数显示 -->
            <TextView
                android:id="@+id/tvRound"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center|bottom"
                android:layout_marginBottom="8pt"
                android:text="1"
                android:textColor="@color/colorBrandOnPrimary"
                android:textSize="10pt"
                android:textStyle="bold" />

        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- 步骤详情面板（可展开） -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSteps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16pt"
        app:cardElevation="6pt"
        app:cardBackgroundColor="@color/colorBrandPrimary"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12pt"
            android:minWidth="200pt"
            android:maxWidth="280pt"
            android:maxHeight="400pt">

            <!-- 头部：标题 + 关闭按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8pt">

                <TextView
                    android:id="@+id/tvStepsTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/floating_steps_title"
                    android:textColor="@color/colorBrandOnPrimary"
                    android:textSize="12pt"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivStepsClose"
                    android:layout_width="20pt"
                    android:layout_height="20pt"
                    android:src="@drawable/ic_close"
                    android:contentDescription="@string/cd_close"
                    app:tint="@color/colorBrandOnPrimary"
                    android:padding="2pt" />

            </LinearLayout>

            <!-- 当前轮数 -->
            <TextView
                android:id="@+id/tvStepsRound"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/floating_steps_round"
                android:textColor="@color/colorBrandOnPrimary"
                android:textSize="10pt"
                android:alpha="0.8"
                android:layout_marginBottom="6pt" />

            <TextView
                android:id="@+id/tvStepsCurrentAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/floating_step_waiting"
                android:textColor="@color/colorBrandOnPrimary"
                android:textSize="11pt"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="8pt" />

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1pt"
                android:background="@color/colorBrandOnPrimary"
                android:alpha="0.2"
                android:layout_marginBottom="6pt" />

            <!-- 步骤列表（可滚动） -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="280pt"
                android:scrollbars="vertical"
                android:fadeScrollbars="true">

                <LinearLayout
                    android:id="@+id/llStepsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </ScrollView>

            <!-- 底部收起提示 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6pt"
                android:gravity="center"
                android:text="@string/floating_tap_to_collapse"
                android:textColor="@color/colorBrandOnPrimary"
                android:alpha="0.5"
                android:textSize="8pt" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- 任务完成状态 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSuccess"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="28pt"
        app:cardElevation="4pt"
        app:cardBackgroundColor="@color/colorSuccessPrimary"
        android:visibility="gone">

        <ImageView
            android:layout_width="32pt"
            android:layout_height="32pt"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_task_success"
            android:src="@drawable/ic_check"
            app:tint="@color/colorBrandOnPrimary" />

    </com.google.android.material.card.MaterialCardView>

    <!-- 任务失败状态 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardError"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="28pt"
        app:cardElevation="4pt"
        app:cardBackgroundColor="@color/colorErrorPrimary"
        android:visibility="gone">

        <ImageView
            android:layout_width="32pt"
            android:layout_height="32pt"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_task_error"
            android:src="@drawable/ic_close"
            app:tint="@color/colorErrorOnPrimary" />

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
